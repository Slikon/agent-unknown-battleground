{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"]
  },
  // ../shared/src must be in scope: tsx only applies compilerOptions (notably
  // experimentalDecorators, needed by @colyseus/schema) to files matched by
  // this tsconfig, and shared is consumed as raw .ts source.
  "include": ["src", "../shared/src"]
}
